# --- استيراد المكتبات الرياضية ---
import math

# --- المعطيات (Inputs) ---
m = 0.4    # الكتلة بالكيلوغرام
k = 40     # ثابت الصلابة (نيوتن/متر)
xmax = 0.1 # السعة (بالمتر)

# --- القوانين والحل (The Logic) ---

# 1. حساب الدور الخاص: T0 = 2 * pi * sqrt(m/k)
t0 = 2 * math.pi * math.sqrt(m / k)

# 2. حساب الطاقة الكلية: E = 0.5 * k * (xmax^2)
energy = 0.5 * k * (xmax ** 2)

# --- عرض النتائج (Outputs) ---
print("شرح الحل من المهندسة علياء:")
print(f"1. حساب الدور: نستخدم القانون T0 = 2π√(m/k)")
print(f"   النتيجة: T0 = {t0:.2f} ثانية")

print(f"2. حساب الطاقة: نستخدم القانون E = 1/2 k.Xmax^2")
print(f"   النتيجة: E = {energy:.2f} جول")
print("-" * 40)
print("تم الحل برمجياً بنجاح!")
