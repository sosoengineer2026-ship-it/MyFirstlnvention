# --- الحل الرياضي ---
import math

m = 0.4  # الكتلة
k = 10   # ثابت الصلابة

# قانون الدور الخاص T0 = 2 * pi * sqrt(m/k)
t0 = 2 * math.pi * math.sqrt(m / k)

print("حل المهندسة علياء:")
print(f"النتيجة: T0 = {t0:.2f} ثانية")
